<?xml version="1.0" encoding="UTF-8"?>

<?import com.custom.components.MenuComponent?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.paint.Color?>

<Pane fx:id="rootDay" maxHeight="750.0" maxWidth="400.0" minHeight="750.0" minWidth="400.0" prefHeight="750.0" prefWidth="400.0" stylesheets="@../Other/homeStyles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ControllerTodayScene">
   <children>
      <Pane fx:id="bubble" layoutX="12.0" layoutY="-20.0" maxWidth="375.0" minWidth="375.0" prefHeight="430.0" prefWidth="375.0" translateY="40.0">
         <children>
            <TextField fx:id="mainTemp" alignment="CENTER" editable="false" layoutX="98.0" layoutY="49.0" maxHeight="100.0" maxWidth="180.0" minHeight="75.0" minWidth="122.0" prefHeight="75.0" prefWidth="180.0" promptText="Loading..." scaleX="3.0" scaleY="3.0" text="67°F"> </TextField>
            <TextField fx:id="foreDesc" alignment="CENTER" editable="false" layoutX="9.0" layoutY="161.0" prefHeight="75.0" prefWidth="358.0" promptText="Loading..." text="why is everything 67 :("> </TextField>
            <Pane fx:id="precipPane" layoutX="211.0" layoutY="252.0" prefHeight="100.0" prefWidth="150.0">
               <children>
                  <TextField fx:id="basicCHANCE" alignment="CENTER" editable="false" layoutX="-15.0" layoutY="55.0" scaleY="0.75" text="Chance of"> </TextField>
                  <TextField fx:id="basicPRECIP" alignment="CENTER" editable="false" layoutX="-15.0" layoutY="70.0" scaleY="0.75" text="Precipitation"> </TextField>
                  <TextField fx:id="mainPrecip" alignment="CENTER" editable="false" layoutX="-15.0" layoutY="20.0" scaleX="3.0" scaleY="3.0" text="67%"> </TextField>
               </children>
            </Pane>
            <HBox fx:id="windBox" layoutX="14.0" layoutY="252.0" prefHeight="100.0" prefWidth="150.0">
               <children>
                  <Pane fx:id="windPane" prefHeight="200.0" prefWidth="200.0">
                     <children>
                        <Pane fx:id="innerWindPane" layoutX="36.0" prefHeight="100.0" prefWidth="40.0" />
                        <TextField fx:id="mainWindSpeedLow" alignment="CENTER" editable="false" layoutX="-50.0" layoutY="10.0" scaleX="2.0" scaleY="2.0" text="67"> </TextField>
                        <TextField fx:id="mainWindSpeedHigh" alignment="CENTER" editable="false" layoutX="-50.0" layoutY="50.0" scaleX="2.0" scaleY="2.0" text="67"> </TextField>
                        <TextField fx:id="basicTO" alignment="CENTER" editable="false" layoutX="-50.0" layoutY="30.0" scaleX="0.85" scaleY="0.75" text="to"> </TextField>
                        <TextField fx:id="basicMPH" alignment="CENTER" editable="false" layoutX="-50.0" layoutY="70.0" scaleX="0.85" scaleY="0.75" text="MPH"> </TextField>
                     </children>
                  </Pane>
                  <Pane fx:id="windDirPane" prefHeight="200.0" prefWidth="200.0">
                     <children>
                        <Pane fx:id="innerWindDirPane" prefHeight="100.0" prefWidth="40.0" />
                        <TextField fx:id="mainWindDir" alignment="CENTER" editable="false" layoutX="-43.0" layoutY="35.0" scaleX="2.0" scaleY="2.0" text="Dir"> </TextField>
                     </children>
                  </Pane>
               </children>
            </HBox>
         </children>
         <effect>
            <DropShadow blurType="TWO_PASS_BOX" color="#000000bf" height="25.0" offsetX="2.0" offsetY="3.0" radius="12.0" width="25.0" />
         </effect>
      </Pane>
      <Button fx:id="alertsButton" layoutX="21.0" layoutY="603.0" mnemonicParsing="false" prefHeight="50.0" prefWidth="358.0" text="Weather Alerts">
         <effect>
            <DropShadow offsetX="2.0" offsetY="3.0">
               <color>
                  <Color opacity="0.75" />
               </color></DropShadow>
         </effect>
      </Button>
      <Button fx:id="favoritesButton" layoutX="21.0" layoutY="536.0" mnemonicParsing="false" onAction="#onFavoritesClick" prefHeight="50.0" prefWidth="358.0" text="Favorites">
         <effect>
            <DropShadow offsetX="2.0" offsetY="3.0">
               <color>
                  <Color opacity="0.75" />
               </color></DropShadow>
         </effect>
      </Button>
      <TextField fx:id="currLocat" alignment="CENTER" editable="false" layoutX="21.0" layoutY="469.0" prefHeight="50.0" prefWidth="358.0" text="Current Location">
         <effect>
            <DropShadow offsetX="2.0" offsetY="3.0">
               <color>
                  <Color opacity="0.75" />
               </color></DropShadow>
         </effect>
      </TextField>
      <MenuComponent fx:id="bottomMenu" homeOn="false" />
   </children>
   <padding>
      <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
   </padding>
</Pane>
